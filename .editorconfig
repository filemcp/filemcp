# EditorConfig — https://editorconfig.org
# Consistent editor settings across contributors.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown — preserve trailing whitespace (used for hard line breaks)
[*.md]
trim_trailing_whitespace = false

# Makefile-style files require tabs
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 2

# YAML — strict 2-space indent (yamllint defaults)
[*.{yml,yaml}]
indent_size = 2
