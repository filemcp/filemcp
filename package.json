{
  "name": "cdnmcp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @cdnmcp/api dev",
    "dev:web": "pnpm --filter @cdnmcp/web dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "build:api": "pnpm --filter @cdnmcp/api build",
    "build:web": "pnpm --filter @cdnmcp/web build",
    "db:migrate": "pnpm --filter @cdnmcp/api db:migrate",
    "db:studio": "pnpm --filter @cdnmcp/api db:studio",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
