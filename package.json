{
  "name": "filemcp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @filemcp/api dev",
    "dev:web": "pnpm --filter @filemcp/web dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "build:api": "pnpm --filter @filemcp/api build",
    "build:web": "pnpm --filter @filemcp/web build",
    "db:migrate": "pnpm --filter @filemcp/api db:migrate",
    "db:studio": "pnpm --filter @filemcp/api db:studio",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "msgpackr-extract"]
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^6.0.3"
  }
}
