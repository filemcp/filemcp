# Database
DATABASE_URL="postgresql://filemcp:filemcp@localhost:5432/filemcp"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="filemcp-assets"
S3_ACCESS_KEY="filemcp"
S3_SECRET_KEY="filemcp_secret"
S3_PUBLIC_URL="http://localhost:9000/filemcp-assets"

# App
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
PORT=4000

# Rate limiting
UPLOAD_RATE_LIMIT_PER_DAY=100
UPLOAD_RATE_LIMIT_BURST=10
