# Database
DATABASE_URL="postgresql://filemcp:filemcp@postgres:5432/filemcp"

# Redis
REDIS_URL="redis://redis:6379"

# JWT — generate a strong random secret for production
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# S3 / MinIO
# Local dev defaults match docker-compose.yml; replace with real S3/R2 values in production
S3_ENDPOINT="http://minio:9000"
S3_REGION="us-east-1"
S3_BUCKET="filemcp-assets"
S3_ACCESS_KEY="filemcp"
S3_SECRET_KEY="filemcp_secret"
S3_PUBLIC_URL="http://localhost:9000/filemcp-assets"

# MinIO admin credentials (must match S3_ACCESS_KEY / S3_SECRET_KEY for local dev)
MINIO_ROOT_USER="filemcp"
MINIO_ROOT_PASSWORD="filemcp_secret"

# App URLs
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
PORT=4000

# Nuxt — server-side SSR calls go container-to-container; browser calls go direct
NUXT_API_URL="http://api:4000/api"
NUXT_PUBLIC_API_URL="/api"

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000"

# Rate limiting
UPLOAD_RATE_LIMIT_PER_DAY=100
UPLOAD_RATE_LIMIT_BURST=10

# Org asset limits
ORG_ASSET_LIMIT=10
ORG_ASSET_LIMIT_PER_MEMBER=5

# MCP upload limits
MCP_MAX_FILE_SIZE_MB=5
